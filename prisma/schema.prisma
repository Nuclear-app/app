generator client {
  provider = "prisma-client-js"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id    String  @id @default(uuid())
  email String  @unique
  name  String?
  posts Block[]
}

model Block {
  id             String           @id @default(uuid())
  createdAt      DateTime         @default(now())
  title          String
  Note           String?
  authorId       String
  folderId       String?
  author         User             @relation(fields: [authorId], references: [id])
  folder         Folder?          @relation(fields: [folderId], references: [id])
  examples       Example[]
  FillInTheBlank FillInTheBlank[]
  questions      Question[]
  quizzes        Quiz[]
}

model Quiz {
  id         String   @id @default(uuid())
  question   String
  answers    String[]
  correctAns String
  mistake    String?
  blockId    String
  block      Block    @relation(fields: [blockId], references: [id])
}

model Example {
  id      String @id @default(uuid())
  topic   String
  example String
  blockId String
  block   Block  @relation(fields: [blockId], references: [id])
}

model Question {
  id       String @id @default(uuid())
  question String
  answer   String
  blockId  String
  block    Block  @relation(fields: [blockId], references: [id])
}

model Folder {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  blocks    Block[]
}

model FillInTheBlank {
  id       String  @id
  sentence String
  answer   String
  hint     String?
  blockId  String
  Block    Block   @relation(fields: [blockId], references: [id])
}
